import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
        int a;
     Scanner s= new Scanner(System.in);
        a=s.nextInt();
        int original=a;
        int reverse=0;
        while(a>0){
            int digit=a%10;
            reverse=reverse*10+digit;
            a=a/10;
        }
        if (original==reverse)
        {
            
        System.out.println("Palindrome");
        }
        
            else{
                System.out.println("Not Palindrome");
            }
    }
}
    
        
        
        
        
        
    
        
        
        
        
    
